{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif
%}

<style>
  #styling-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #styling-{{ section.id }} .styling__grid {
    display: grid;
    gap: 32px;
  }
  @media (min-width: 768px) {
    #styling-{{ section.id }} .styling__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  #styling-{{ section.id }} .styling-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  #styling-{{ section.id }} .styling-card__image img,
  #styling-{{ section.id }} .styling-card__image svg {
    width: 100%;
    object-fit: cover;
    border-radius: var(--radius-base, 18px);
  }
  #styling-{{ section.id }} .styling-card__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-secondary));
  }
  #styling-{{ section.id }} .styling-card__title {
    font-size: 1.15rem;
    line-height: 1.5;
  }
  #styling-{{ section.id }} .styling-card__copy {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgb(var(--color-foreground-secondary));
  }
</style>

<section
  id="styling-{{ section.id }}"
  class="m-section styling m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
  data-section-type="product-styling-inspiration"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-my m-section-py">
    {% render 'index-section-header', section_settings: section.settings %}
    {% if section.blocks.size > 0 %}
      <div class="styling__grid">
        {% for block in section.blocks %}
          <article class="styling-card {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}" {% if animated %}data-cascade style="--animation-order: {{ forloop.index }}"{% endif %} {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="styling-card__image">
                {% render 'responsive-image', image: block.settings.image, image_class: 'm:w-full m:h-full' %}
              </div>
            {% endif %}
            <div>
              {% if block.settings.eyebrow != blank %}
                <p class="styling-card__eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="styling-card__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.copy != blank %}
                <p class="styling-card__copy">{{ block.settings.copy }}</p>
              {% endif %}
            </div>
            {% if block.settings.button_label != blank %}
              <div>
                <a class="m-button m-button--link" href="{{ block.settings.button_link | default: '#' }}">{{ block.settings.button_label }}</a>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Styling inspiration",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Fixed width" },
        { "value": "container-fluid", "label": "Stretched width" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Editorial styling"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Equip your wardrobe for every chapter."
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animation",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit global" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in up" },
        { "value": "fade-in-left", "label": "Fade in left" },
        { "value": "fade-in-right", "label": "Fade in right" }
      ]
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Styling card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Desk to dinner"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Layer with the Celeste silk dress"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Structured ease that transitions seamlessly from strategy session to evening."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Link label",
          "default": "Shop the pairing"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Styling inspiration",
      "blocks": [
        { "type": "look" },
        { "type": "look" },
        { "type": "look" }
      ]
    }
  ]
}
{% endschema %}
