{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif
%}

<style>
  #craftsmanship-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #craftsmanship-{{ section.id }} .craftsmanship__inner {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 992px) {
    #craftsmanship-{{ section.id }} .craftsmanship__inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 64px;
    }
  }
  #craftsmanship-{{ section.id }} .craftsmanship__eyebrow {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    color: rgb(var(--color-foreground-secondary));
  }
  #craftsmanship-{{ section.id }} .craftsmanship__headline {
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  #craftsmanship-{{ section.id }} .craftsmanship__body {
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.8;
    color: rgb(var(--color-foreground-secondary));
  }
  #craftsmanship-{{ section.id }} .craftsmanship__list {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.5rem;
  }
  #craftsmanship-{{ section.id }} .craftsmanship__list-item-title {
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }
  #craftsmanship-{{ section.id }} .craftsmanship__list-item-copy {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgb(var(--color-foreground-secondary));
  }
</style>

<section
  id="craftsmanship-{{ section.id }}"
  class="m-section craftsmanship m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
  data-section-type="product-craftsmanship"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-my m-section-py">
    <div class="craftsmanship__inner">
      <div class="craftsmanship__media {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}" {% if animated %}data-cascade style="--animation-order:1;"{% endif %}>
        {% if section.settings.image != blank %}
          {% render 'responsive-image', image: section.settings.image, wrapper_class: 'm:blocks-radius' %}
        {% elsif section.settings.video_url != blank %}
          {% liquid
            assign poster = ''
            if section.settings.video_poster != blank
              assign poster = section.settings.video_poster | image_url: width: 1200
            elsif section.settings.image != blank
              assign poster = section.settings.image | image_url: width: 1200
            endif
          %}
          <div class="craftsmanship__video">
            <video playsinline muted {% if section.settings.video_autoplay %}autoplay loop{% endif %}{% if poster != '' %} poster="{{ poster }}"{% endif %} style="width:100%; border-radius: var(--radius-base, 12px);">
              <source src="{{ section.settings.video_url }}" type="video/mp4">
            </video>
          </div>
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'm-placeholder-svg m:blocks-radius' }}
        {% endif %}
      </div>
      <div class="craftsmanship__content {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}" {% if animated %}data-cascade style="--animation-order:2;"{% endif %}>
        {% if section.settings.eyebrow != blank %}
          <p class="craftsmanship__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="craftsmanship__headline">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="craftsmanship__body rte">{{ section.settings.body }}</div>
        {% endif %}
        {% if section.blocks.size > 0 %}
          <div class="craftsmanship__list">
            {% for block in section.blocks %}
              <div class="craftsmanship__list-item" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <p class="craftsmanship__list-item-title">{{ block.settings.title }}</p>
                {% endif %}
                {% if block.settings.copy != blank %}
                  <p class="craftsmanship__list-item-copy">{{ block.settings.copy }}</p>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
        {% if section.settings.cta_label != blank %}
          <div class="m-section__actions" style="margin-top:2.5rem;">
            <a class="m-button m-button--link" href="{{ section.settings.cta_link | default: '#' }}">{{ section.settings.cta_label }}</a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fabric & craftsmanship",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Stretched width" },
        { "value": "container", "label": "Fixed width" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow heading",
      "default": "European ateliers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Tailored by artisans who honour every stitch"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>Every piece is cut in small batches from regenerative wool, woven at a fourth-generation mill in Biella, Italy. Hand-finished seams and silk-bound interiors ensure it drapes as beautifully inside as it does on the body.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Optional video URL"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay video",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video poster image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "Discover our atelier"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animation",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit global" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in up" },
        { "value": "fade-in-right", "label": "Fade in right" },
        { "value": "fade-in-left", "label": "Fade in left" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 120,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Craft detail",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Responsible fibres"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Traceable merino with natural stretch, certified for low-impact dyes."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Fabric & craftsmanship",
      "blocks": [
        { "type": "pillar" },
        { "type": "pillar" },
        { "type": "pillar" }
      ]
    }
  ]
}
{% endschema %}
