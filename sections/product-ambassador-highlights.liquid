{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif
%}

<style>
  #ambassadors-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #ambassadors-{{ section.id }} .ambassadors__grid {
    display: grid;
    gap: 32px;
  }
  @media (min-width: 768px) {
    #ambassadors-{{ section.id }} .ambassadors__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  #ambassadors-{{ section.id }} .ambassador-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  #ambassadors-{{ section.id }} .ambassador-card__image img,
  #ambassadors-{{ section.id }} .ambassador-card__image svg {
    width: 100%;
    border-radius: var(--radius-base, 16px);
    object-fit: cover;
  }
  #ambassadors-{{ section.id }} .ambassador-card__name {
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  #ambassadors-{{ section.id }} .ambassador-card__role {
    font-size: 0.85rem;
    color: rgb(var(--color-foreground-secondary));
    margin-top: 0.25rem;
  }
  #ambassadors-{{ section.id }} .ambassador-card__quote {
    font-size: 1rem;
    line-height: 1.8;
    color: rgb(var(--color-foreground-secondary));
  }
</style>

<section
  id="ambassadors-{{ section.id }}"
  class="m-section ambassadors m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
  data-section-type="product-ambassador-highlights"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-my m-section-py">
    {% render 'index-section-header', section_settings: section.settings %}
    {% if section.blocks.size > 0 %}
      <div class="ambassadors__grid">
        {% for block in section.blocks %}
          <article class="ambassador-card {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}" {% if animated %}data-cascade style="--animation-order: {{ forloop.index }}"{% endif %} {{ block.shopify_attributes }}>
            <div class="ambassador-card__image">
              {% if block.settings.image != blank %}
                {% render 'responsive-image', image: block.settings.image, image_class: 'm:w-full m:h-full' %}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'm-placeholder-svg' }}
              {% endif %}
            </div>
            <div>
              {% if block.settings.name != blank %}
                <p class="ambassador-card__name">{{ block.settings.name }}</p>
              {% endif %}
              {% if block.settings.role != blank %}
                <p class="ambassador-card__role">{{ block.settings.role }}</p>
              {% endif %}
            </div>
            {% if block.settings.quote != blank %}
              <blockquote class="ambassador-card__quote">{{ block.settings.quote }}</blockquote>
            {% endif %}
            {% if block.settings.link_label != blank %}
              <div>
                <a class="m-button m-button--link" href="{{ block.settings.link | default: '#' }}">{{ block.settings.link_label }}</a>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Ambassador highlights",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Stretched width" },
        { "value": "container", "label": "Fixed width" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxe Icons"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Seen on women building the future."
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animation",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit global" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in up" },
        { "value": "fade-in-right", "label": "Fade in right" },
        { "value": "fade-in-left", "label": "Fade in left" }
      ]
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 100,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "ambassador",
      "name": "Ambassador",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Amelia Tan"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Creative Director, Atelier A"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "“The drape is sublime — I can step from boardroom to gallery opening without a change.”"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "View their edit"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Ambassador highlights",
      "blocks": [
        { "type": "ambassador" },
        { "type": "ambassador" },
        { "type": "ambassador" }
      ]
    }
  ]
}
{% endschema %}
