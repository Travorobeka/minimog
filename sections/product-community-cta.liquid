{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif
%}

<style>
  #community-cta-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #community-cta-{{ section.id }} .community-cta {
    border-radius: var(--radius-base, 20px);
    padding: clamp(2.5rem, 6vw, 4rem);
    background: rgba(var(--color-foreground), 0.04);
    display: grid;
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 992px) {
    #community-cta-{{ section.id }} .community-cta {
      text-align: left;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 3rem;
    }
  }
  #community-cta-{{ section.id }} .community-cta__eyebrow {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-secondary));
  }
  #community-cta-{{ section.id }} .community-cta__headline {
    font-size: clamp(1.75rem, 2.5vw, 2.375rem);
    line-height: 1.2;
    margin-top: 0.75rem;
  }
  #community-cta-{{ section.id }} .community-cta__body {
    margin-top: 1.25rem;
    max-width: 32rem;
    color: rgb(var(--color-foreground-secondary));
    line-height: 1.8;
    font-size: 1rem;
  }
</style>

<section
  id="community-cta-{{ section.id }}"
  class="m-section community-cta m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
  data-section-type="product-community-cta"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-my m-section-py">
    <div class="community-cta {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="community-cta__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="community-cta__headline">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="community-cta__body rte">{{ section.settings.body }}</div>
        {% endif %}
      </div>
      <div>
        {% if section.settings.button_label != blank %}
          <a class="m-button m-button--primary {{ section.settings.button_size }}" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community invitation",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Fixed width" },
        { "value": "container-fluid", "label": "Stretched width" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Luxe Circle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Join the circle shaping tomorrow’s icons"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>Receive private previews, atelier talks, and first access to limited capsules crafted for our community.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Become a member"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "m-button--large",
      "options": [
        { "value": "", "label": "Standard" },
        { "value": "m-button--small", "label": "Compact" },
        { "value": "m-button--large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animation",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit global" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in up" },
        { "value": "fade-in-left", "label": "Fade in left" },
        { "value": "fade-in-right", "label": "Fade in right" }
      ]
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Community invitation"
    }
  ]
}
{% endschema %}
