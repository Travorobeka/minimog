{% comment %}
  All custom CSS in this file will be kept when updating the theme
  Write your custom CSS below
{% endcomment %}

.swiper-pagination {
  gap: 4px !important;
}

.swiper-pagination-bullet {
  width: 1px !important;
  height: 1px !important;
  margin: 0 !important;
  border-width: 1px !important;
  border-radius: 50% !important;
}

.swiper-pagination-bullet-active {
  transform: none !important;
  width: 3px !important;
  height: 3px !important;
}

.main-product__block-title,
.main-product__block-price {
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
}

.main-product__block-title {
  margin-bottom: 0.5rem;
}

.main-product__block-price {
  margin-left: 10px;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}

.main-product__block-title + .main-product__block-price {
  margin-top: 0 !important;
}

.main-product__block-price .m-product-tax,
.main-product__block-price .installment-shoppay {
  flex-basis: 100%;
  margin-left: 0;
  margin-top: 0.25rem;
}

.main-product__block-price .m-product-tax {
  font-size: 0.85rem;
  letter-spacing: 0.01em;
}

.m-product-title {
  font-size: clamp(1.6rem, 2.8vw, 2.2rem);
  font-weight: 500;
  letter-spacing: 0.01em;
}

.main-product__block-price .m-price-item {
  font-size: clamp(1.5rem, 2.6vw, 2.05rem);
}
